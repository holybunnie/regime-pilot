# ============================================================================
# REGIME PILOT — environment variables. Copy to `.env` and fill in.
# `.env` is git-ignored and must NEVER be committed.
# ============================================================================

# --- CoinMarketCap API key (REQUIRED for the data layer) ----------------------
# Where to get it: https://pro.coinmarketcap.com/account  (free "Basic" plan works
# to start; historical OHLCV may need a paid tier — we will TEST your key and tell
# you exactly what it can access).
CMC_API_KEY=

# Explicit source cutover. Keep `binance` through the frozen v2 reveal; use `cmc_pro`
# only with a documented new strategy/data version after the CMC shadow cache verifies.
REGIME_PILOT_PRICE_SOURCE=binance

# --- CoinMarketCap MCP (optional; preferred data path if your key works there) -
# Verified endpoint (returns HTTP 405 on GET = exists, POST-only streamable HTTP):
CMC_MCP_URL=https://mcp.coinmarketcap.com/mcp

# --- BSC (attestation layer) --------------------------------------------------
# Verified reachable JSON-RPC endpoints (chainId 0x38 mainnet, 0x61 testnet):
BSC_MAINNET_RPC=https://bsc-dataseed.bnbchain.org
BSC_TESTNET_RPC=https://bsc-testnet.publicnode.com

# Attestation wallet PRIVATE KEY — must be a BRAND-NEW wallet used for NOTHING
# else, funded with a small amount of BNB for gas only (we estimate < 0.05 BNB).
# How to export from MetaMask: Account details -> Show private key. Paste with the
# leading 0x. This key is read only to sign our own attestation transactions; it
# is never printed to any log (enforced by a test). DO NOT reuse a personal wallet.
ATTEST_PRIVATE_KEY=

# BscScan API key (OPTIONAL — only needed to auto-verify the contract source so
# judges can read it on-chain). Get one free: https://bscscan.com/myapikey
BSCSCAN_API_KEY=

# --- x402 (optional) ----------------------------------------------------------
# Only needed if you want us to execute at least one REAL paid data request
# ($0.01 USDC each, on Base). Private key of a wallet holding a few $ of USDC on
# Base. Leave blank to price x402 from the published schedule without paying.
X402_BASE_PRIVATE_KEY=

# Secret 32-byte hex seed for deterministic commit salts. Auto-generated into .env if
# absent. Required so reveals are reproducible on ephemeral runners. Add as a GitHub
# Actions secret with the same value. Keep secret until reveal day.
ATTEST_SALT_SEED=
