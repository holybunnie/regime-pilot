{
  "meta": {
    "name": "Simple BTC Momentum",
    "version": "0.1.0",
    "author": "Regime Pilot Skill",
    "created_at": "2026-06-13T06:30:00Z",
    "description": "Minimal worked example: hold majors when BTC is above its 7-day average and Fear & Greed is not extreme; otherwise go flat. Demonstrates the schema with the minimum-viable feature set (quotes + Fear & Greed only).",
    "configurations_tried": 3
  },
  "universe": {
    "source": "eligible_list",
    "max_market_cap_rank": 50,
    "min_volume_24h_usd": 10000000
  },
  "features": [
    {
      "name": "btc_sma_7d",
      "source": "btc_price",
      "transform": {
        "kind": "sma",
        "window": 168
      }
    },
    {
      "name": "btc_now",
      "source": "btc_price",
      "transform": {
        "kind": "raw"
      }
    },
    {
      "name": "fg_level",
      "source": "fear_greed",
      "transform": {
        "kind": "raw"
      }
    },
    {
      "name": "btc_vol",
      "source": "btc_price",
      "transform": {
        "kind": "realized_vol",
        "window": 168
      }
    }
  ],
  "regimes": [
    {
      "name": "risk_on",
      "persistence_hours": 8,
      "predicate": {
        "op": "and",
        "args": [
          {
            "op": ">",
            "left": {
              "feature": "btc_now"
            },
            "right": {
              "feature": "btc_sma_7d"
            }
          },
          {
            "op": "<",
            "left": {
              "feature": "fg_level"
            },
            "right": {
              "const": 80
            }
          }
        ]
      }
    },
    {
      "name": "risk_off",
      "persistence_hours": 4,
      "predicate": {
        "const_bool": true
      }
    }
  ],
  "playbooks": {
    "risk_on": {
      "action": "hold_assets",
      "select": {
        "rank_by": "volume_24h",
        "top_n": 5
      },
      "min_hold_hours": 4
    },
    "risk_off": {
      "action": "flat"
    }
  },
  "sizing": {
    "k": 0.5,
    "vol_target_annual": 0.2,
    "asset_vol_feature": "btc_vol",
    "max_position_weight": 0.4
  },
  "risk": {
    "max_drawdown_budget": 0.2,
    "per_asset_cap": 0.4,
    "max_gross_exposure": 1.0,
    "derisk_ladder": [
      {
        "budget_consumed": 0.5,
        "gross_exposure_multiplier": 0.5
      },
      {
        "budget_consumed": 0.75,
        "gross_exposure_multiplier": 0.0,
        "except_regimes": []
      },
      {
        "budget_consumed": 0.9,
        "gross_exposure_multiplier": 0.0
      }
    ]
  },
  "costs": {
    "fee_bps": 10,
    "slippage_bps_floor": 5,
    "slippage_size_coeff": 50,
    "latency_minutes": 60
  }
}
